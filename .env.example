# Docker Compose Environment Variables
# ====================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
#
# This file is used by docker-compose.yml for variable substitution
# Docker Compose reads ${VAR} from .env in the same directory as docker-compose.yml

# Alternative: You can also use POSTGRES_* variables directly
DATABASE_DEFAULT=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

# Frontend build args for docker-compose.prod.yml (optional)
# Omit on production VPS to use defaults (https://datilio.com).
# For local prod-stack testing, add to your root .env:
# VITE_API_URL=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000/api/v1