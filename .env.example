# Root .env — single source for database credentials
# =================================================
# Copy to .env and fill in values. Used by:
#   - docker-compose (Postgres container)
#   - backend + celery (via env_file in compose)
#   - Alembic migrations
# DO NOT commit .env

DATABASE_DEFAULT=datilio_db
DATABASE_USER=postgres
# Use quotes if password contains # @ ! or spaces (e.g. DATABASE_PASSWORD="Hjk!@#45")
DATABASE_PASSWORD=your_database_password
# Docker Compose: use service name "postgres". Local Python (no Docker): use "localhost"
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Optional tuning
# GUNICORN_WORKERS=2
# CELERY_CONCURRENCY=2

# Frontend build arg — both frontends use VITE_API_URL (server origin; /api/v1 added in code)
# Local:
VITE_API_URL=http://localhost:8000
# Production VPS: omit to default to https://datilio.com
