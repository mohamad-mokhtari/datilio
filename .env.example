# Root .env — single source for database credentials
# =================================================
# Copy to .env and fill in values. Used by:
#   - docker-compose (Postgres container)
#   - backend + celery (via env_file in compose)
#   - Alembic migrations
# DO NOT commit .env

DATABASE_DEFAULT=datilio_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password
# Docker Compose: use service name "postgres". Local Python (no Docker): use "localhost"
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Frontend build args for docker-compose.prod.yml (optional)
# Omit on production VPS to use defaults (https://datilio.com).
# For local prod-stack testing:
# VITE_API_URL=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000/api/v1
