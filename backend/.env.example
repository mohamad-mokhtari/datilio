# Backend .env — app secrets and services (NO database credentials here)
# ========================================================================
# Database: set DATABASE_* in the repo root .env only (see ../.env.example)
# Copy to .env and fill in values. DO NOT commit .env

JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here

OPENAI_API_KEY=your_openai_api_key_here

STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_SUCCESS_URL=https://front.datilio.com/pricing/success
STRIPE_CANCEL_URL=https://front.datilio.com/pricing/cancel

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username@gmail.com
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=your_email@gmail.com
CONTACT_EMAIL=your_contact_email@gmail.com

# Frontend URLs Configuration
# # ------------------- Development:
# FRONTEND_BASE_URL=http://localhost:3000
# ADMIN_FRONTEND_BASE_URL=http://localhost:3001
# ------------------- Production (uncomment and use these in production):
FRONTEND_BASE_URL=https://front.datilio.com
ADMIN_FRONTEND_BASE_URL=https://admin.datilio.com
# Public API origin for absolute static URLs (feedback images). Optional — inferred from FRONTEND_BASE_URL on datilio.com.
# BACKEND_BASE_URL=https://datilio.com

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

BUYMEACOFFEE_URL=https://buymeacoffee.com/datilio
